# ₸USD Federal Meme Reserve Bot — Environment Variables
# Copy this to .env and fill in your values

# ═══════════════════════════════════════════════════════════
# Telegram Bot
# ═══════════════════════════════════════════════════════════
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Your Telegram chat ID (for auth whitelist)
OWNER_CHAT_ID=your_chat_id_here

# ═══════════════════════════════════════════════════════════
# RPC
# ═══════════════════════════════════════════════════════════
RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ═══════════════════════════════════════════════════════════
# Hot Wallets
# ═══════════════════════════════════════════════════════════
# Wallet #1 — Burn caller (signs BurnEngine.executeFullCycle only)
# Address: 0x52b26dB29BC46160270941e301CF6f0ea67f84C7
# Fund with ~0.005 ETH for gas
BURN_CALLER_PRIVATE_KEY=0x_your_burn_wallet_private_key

# Wallet #2 — Treasury operator (signs TreasuryManager buyback/burn)
# Address: 0x4e89764184AF782889D7F6711F5548e27203652a
# Fund with ~0.01 ETH for gas
TREASURY_OPERATOR_PRIVATE_KEY=0x_your_treasury_wallet_private_key

# ═══════════════════════════════════════════════════════════
# Contract Addresses (fill after deployment)
# ═══════════════════════════════════════════════════════════
BURN_ENGINE_ADDRESS=0x996A533AF55F6E7230f44D9a36B21E659509122c
TREASURY_MANAGER_ADDRESS=0x3dbF93D110C677A1c063A600cb42940262f3BBd6

# ═══════════════════════════════════════════════════════════
# AI (Anthropic Claude)
# ═══════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=your_anthropic_api_key

# ═══════════════════════════════════════════════════════════
# Macro Data (FRED — free at fred.stlouisfed.org)
# ═══════════════════════════════════════════════════════════
FRED_API_KEY=your_fred_api_key
